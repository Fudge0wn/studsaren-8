# Normalize all text files to LF in the repo and on checkout.
# This repo runs on a Linux Raspberry Pi (Docker, shell, configs) — LF is required.
* text=auto eol=lf

# Explicit LF for files that must never be CRLF
*.sh    text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.conf  text eol=lf
*.js    text eol=lf
*.json  text eol=lf
Dockerfile text eol=lf
